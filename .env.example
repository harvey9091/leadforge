# =============================================================================
# Leadforge — Production Environment Variables
# =============================================================================
#
# Copy this file to `.env` and fill in the values before running:
#   docker compose up -d
#
# NEVER commit the real `.env` file.
# =============================================================================

# ----- Application -----
NODE_ENV=production
APP_URL=https://leadforge.example.com
LOG_LEVEL=info
VERSION=8.0.0-production
PORT=3001

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql://leadforge:CHANGE_ME@postgres:5432/leadforge
POSTGRES_DB=leadforge
POSTGRES_USER=leadforge
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ----- Redis -----
REDIS_URL=redis://redis:6379

# ----- RabbitMQ -----
RABBITMQ_URL=amqp://leadforge:CHANGE_ME@rabbitmq:5672
RABBITMQ_USER=leadforge
RABBITMQ_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ----- Auth / JWT -----
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

# ----- FreeLLM (Server 2 — External AI Infrastructure) -----
# OpenAI-compatible API on automation-server-2
# Replace with your actual Server 2 IP and port
FREELLM_BASE_URL=http://YOUR_SERVER_2_IP:3002/v1
FREELLM_API_KEY=YOUR_FREELLM_API_KEY_HERE
FREELLM_MODEL=auto

# AI tuning
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4000
AI_TIMEOUT=60000
AI_RETRIES=3

# ----- Firecrawl (Server 2 — External Scraping) -----
# Firecrawl instance on automation-server-2
# Replace with your actual Server 2 IP and port
FIRECRAWL_URL=http://YOUR_SERVER_2_IP:3003
FIRECRAWL_API_KEY=
FIRECRAWL_TIMEOUT=30000
FIRECRAWL_MAX_RETRIES=2

# ----- Worker Configuration -----
WORKER_COUNT=2
DISCOVERY_WORKER_COUNT=2
DISCOVERY_CONCURRENCY=3
DISCOVERY_POLL_INTERVAL_MS=5000
DISCOVERY_HEARTBEAT_TIMEOUT_MS=60000
ENRICHMENT_CONCURRENCY=2
ENRICHMENT_POLL_INTERVAL_MS=15000
ENRICHMENT_HEARTBEAT_TIMEOUT_MS=180000
AI_CONCURRENCY=2
AI_POLL_INTERVAL_MS=10000
AI_HEARTBEAT_TIMEOUT_MS=180000
EXPORT_CONCURRENCY=1

# ----- Rate Limiting -----
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=120

# ----- Seed (set to true ONLY on first deploy) -----
SEED_ON_BOOT=false
